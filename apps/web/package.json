{
  "name": "@beach-kings/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "clean": "rm -rf .next out dist",
    "test:e2e:setup": "node tests/e2e/setup/ensure-test-infra.js",
    "test:e2e": "npm run test:e2e:setup && playwright test",
    "test:e2e:ui": "npm run test:e2e:setup && playwright test --ui",
    "test:e2e:debug": "npm run test:e2e:setup && playwright test --debug",
    "test:e2e:headed": "npm run test:e2e:setup && playwright test --headed",
    "test:e2e:file": "npm run test:e2e:setup && playwright test",
    "test:e2e:grep": "npm run test:e2e:setup && playwright test --grep",
    "test:e2e:mobile": "npm run test:e2e:setup && MOBILE=1 playwright test --project=mobile-chrome",
    "test:e2e:all-viewports": "npm run test:e2e:setup && MOBILE=1 playwright test",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "@react-oauth/google": "^0.13.4",
    "axios": "^1.13.1",
    "eventsource-parser": "^3.0.6",
    "heic-to": "^1.0.2",
    "lucide-react": "^0.552.0",
    "mapbox-gl": "^3.18.1",
    "next": "^16.0.8",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-easy-crop": "^5.5.6",
    "react-map-gl": "^8.1.0",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitest/coverage-v8": "^4.1.0",
    "axios": "^1.13.1",
    "concurrently": "^9.1.0",
    "eslint": "^9.36.0",
    "eslint-config-next": "^16.0.8",
    "jsdom": "^20.0.3",
    "libphonenumber-js": "^1.12.33",
    "pg": "^8.13.1",
    "playwright": "^1.48.0",
    "vitest": "^4.1.0"
  }
}
