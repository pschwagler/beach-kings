# Worktree Environment Template
# Copy to .env in your worktree and adjust port numbers to avoid conflicts.
# Each worktree needs unique ports so multiple dev stacks can run simultaneously.

COMPOSE_PROJECT_NAME=beach-kings-wt1

# Backend
BACKEND_PORT=8010
BACKEND_INTERNAL_PORT=8010

# Frontend
FRONTEND_PORT=3010

# Database
POSTGRES_PORT=5442

# Redis
REDIS_PORT=6389

# Debug
DEBUGPY_PORT=5688

# CORS — must match your frontend port
ALLOWED_ORIGINS=http://localhost:3010

# Next.js backend proxying — must match your backend port
BACKEND_PROXY_TARGET=http://localhost:8010
BACKEND_INTERNAL_URL=http://localhost:8010
