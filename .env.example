# Beach League - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# PostgreSQL Database
# =============================================================================
POSTGRES_USER=beachkings
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=beachkings
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# =============================================================================
# Application Settings
# =============================================================================
# CRITICAL: Generate a secure random key for production
# Example: openssl rand -hex 32
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRATION_HOURS=1
# Refresh token lifetime in days (tokens rotate on each use)
REFRESH_TOKEN_EXPIRATION_DAYS=30

# Set to "production" to disable auto-reload
ENV=development

# Comma-separated list of allowed CORS origins
# Production: https://beachleaguevb.com,https://dev.beachleaguevb.com
ALLOWED_ORIGINS=http://localhost:3000

# =============================================================================
# WhatsApp Service (optional)
# =============================================================================
ENABLE_WHATSAPP=true

# =============================================================================
# Twilio SMS (optional)
# =============================================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Set to false to disable SMS sending (default: true)
ENABLE_SMS=true

# =============================================================================
# SendGrid Email (optional)
# =============================================================================
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@beachleaguevb.com
ADMIN_EMAIL=admin@beachleaguevb.com
# Set to false to disable email sending (default: true)
ENABLE_EMAIL=true

# =============================================================================
# Port Configuration (usually leave as defaults)
# =============================================================================
BACKEND_PORT=8000
WHATSAPP_PORT=3001

# In development, Next.js proxies /api to this URL. Default 8000.
# E2E sets BACKEND_PROXY_TARGET=http://localhost:8001 so the test frontend talks to the test backend.
# Not needed for production (use NEXT_PUBLIC_API_URL at build time instead).
# BACKEND_PROXY_TARGET=http://localhost:8000

# Internal URL for server-side rendering (SSR) calls from Next.js to backend.
# - Docker: http://backend:8000 (container-to-container, set in docker-compose.yml)
# - Local dev: http://localhost:8000 (same host)
# Used by server-fetch.js for sitemap, public pages, and other SSR data fetching.
BACKEND_INTERNAL_URL=http://localhost:8000


GEOAPIFY_API_KEY=MY_KEY

# =============================================================================
# Google SSO (optional)
# =============================================================================
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# =============================================================================
# Gemini (photo score extraction)
# =============================================================================
# Use GEMINI_API_KEY or GOOGLE_API_KEY
GEMINI_API_KEY=

# =============================================================================
# Google Places API (court photo discovery)
# =============================================================================
GOOGLE_PLACES_API_KEY=

# =============================================================================
# AWS S3 (avatar uploads)
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=us-west-2

# =============================================================================
# Mobile App (Expo)
# =============================================================================
# Base URL the Expo app uses to reach the backend.
# - iOS simulator: http://localhost:8000 works (shares host network).
# - Physical device via Expo Go: use your Mac's LAN IP, e.g. http://192.168.1.42:8000
#   Find it with: ipconfig getifaddr en0
# Requires BACKEND_BIND_HOST=0.0.0.0 (below) so Docker exposes the backend to the LAN.
# Only vars prefixed EXPO_PUBLIC_* are bundled into the client.
EXPO_PUBLIC_API_URL=http://localhost:8000

# Bind host for the backend container's published port.
# Default 127.0.0.1 (localhost-only, secure). Set to 0.0.0.0 to expose on LAN
# for testing the mobile app on a physical device.
BACKEND_BIND_HOST=127.0.0.1

# =============================================================================
# System Admin
# =============================================================================
# Phone number (E.164 format) to seed as the default system admin on startup.
# Leave empty to skip admin seeding.
DEFAULT_ADMIN_PHONE=+15550000000